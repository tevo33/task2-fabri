<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Lista de Lancamentos</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <main class="container">
      <header class="header header-row">
        <div>
          <p class="eyebrow">Task 2</p>
          <h1>Registro de despesas e receitas</h1>
          <p class="subtitle">Listagem simples dos lancamentos cadastrados.</p>
        </div>
        <div class="header-actions">
          <a class="button" href="/registrar">Registrar despesa</a>
          <a class="button button-secondary" href="/lancamentos/pdf<%= filterQueryString ? '?' + filterQueryString : '' %>">Exportar PDF</a>
          <form method="post" action="/logout">
            <button class="button button-secondary" type="submit">Sair</button>
          </form>
        </div>
      </header>

      <% if (error) { %>
        <section class="alert">
          <strong>Erro:</strong> <%= error %>
        </section>
      <% } %>

      <% if (flash) { %>
        <section class="alert <%= flash.type === 'success' ? 'alert-success' : '' %>">
          <strong><%= flash.type === 'success' ? 'Sucesso:' : 'Aviso:' %></strong> <%= flash.message %>
        </section>
      <% } %>

      <section class="card form-card">
        <form method="get" action="/" class="form-grid filters-grid">
          <label>
            Data inicial
            <input type="date" name="data_inicio" value="<%= filters.data_inicio %>" />
          </label>

          <label>
            Data final
            <input type="date" name="data_fim" value="<%= filters.data_fim %>" />
          </label>

          <label>
            Situacao
            <select name="situacao">
              <option value="">Todas</option>
              <% statusOptions.forEach((status) => { %>
                <option value="<%= status %>" <%= filters.situacao === status ? 'selected' : '' %>><%= status %></option>
              <% }) %>
            </select>
          </label>

          <div class="actions">
            <button class="button" type="submit">Filtrar</button>
            <a class="button button-secondary" href="/">Limpar filtros</a>
          </div>
        </form>
      </section>

      <section class="card">
        <table>
          <thead>
            <tr>
              <th>ID</th>
              <th>Descricao</th>
              <th>Data</th>
              <th>Valor</th>
              <th>Tipo</th>
              <th>Situacao</th>
            </tr>
          </thead>
          <tbody>
            <% if (lancamentos.length === 0) { %>
              <tr>
                <td colspan="6" class="empty">Nenhum lancamento encontrado.</td>
              </tr>
            <% } %>

            <% lancamentos.forEach((lancamento) => { %>
              <tr>
                <td><%= lancamento.id %></td>
                <td><%= lancamento.descricao %></td>
                <td><%= new Date(lancamento.data_lancamento).toLocaleDateString('pt-BR') %></td>
                <td>
                  <%= Number(lancamento.valor).toLocaleString('pt-BR', {
                    style: 'currency',
                    currency: 'BRL'
                  }) %>
                </td>
                <td><span class="tag"><%= lancamento.tipo_lancamento %></span></td>
                <td><%= lancamento.situacao %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </section>
    </main>
  </body>
</html>
