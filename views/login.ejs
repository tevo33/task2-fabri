<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <main class="container login-wrap">
      <section class="card login-card">
        <p class="eyebrow">Task 2</p>
        <h1>Entrar</h1>
        <p class="subtitle">Use o usuario cadastrado para acessar a aplicacao.</p>

        <% if (error) { %>
          <section class="alert">
            <strong>Erro:</strong> <%= error %>
          </section>
        <% } %>

        <form method="post" action="/login" class="form-grid form-grid-single">
          <label>
            Login
            <input type="text" name="login" required />
          </label>

          <label>
            Senha
            <input type="password" name="senha" required />
          </label>

          <div class="actions">
            <button class="button" type="submit">Entrar</button>
          </div>
        </form>
      </section>
    </main>
  </body>
</html>
