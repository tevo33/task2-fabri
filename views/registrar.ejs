<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Registrar Despesa</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <main class="container">
      <header class="header header-row">
        <div>
          <p class="eyebrow">Task 2</p>
          <h1>Registrar despesa</h1>
          <p class="subtitle">Cadastro simples para incluir, editar e excluir despesas.</p>
        </div>
        <div class="header-actions">
          <a class="button button-secondary" href="/">Voltar para home</a>
          <form method="post" action="/logout">
            <button class="button button-secondary" type="submit">Sair</button>
          </form>
        </div>
      </header>

      <% if (error) { %>
        <section class="alert">
          <strong>Erro:</strong> <%= error %>
        </section>
      <% } %>

      <% if (flash) { %>
        <section class="alert <%= flash.type === 'success' ? 'alert-success' : '' %>">
          <strong><%= flash.type === 'success' ? 'Sucesso:' : 'Aviso:' %></strong> <%= flash.message %>
        </section>
      <% } %>

      <section class="card form-card">
        <form
          method="post"
          action="<%= lancamentoEmEdicao ? '/registrar/' + lancamentoEmEdicao.id + '/editar' : '/registrar' %>"
          class="form-grid"
        >
          <label>
            Descricao
            <input
              type="text"
              name="descricao"
              value="<%= lancamentoEmEdicao?.descricao || '' %>"
              required
            />
          </label>

          <label>
            Data
            <input
              type="date"
              name="data_lancamento"
              value="<%= lancamentoEmEdicao?.data_lancamento || '' %>"
              required
            />
          </label>

          <label>
            Valor
            <input
              type="number"
              name="valor"
              step="0.01"
              min="0"
              value="<%= lancamentoEmEdicao?.valor || '' %>"
              required
            />
          </label>

          <label>
            Situacao
            <select name="situacao" required>
              <% expenseStatusOptions.forEach((status) => { %>
                <option value="<%= status %>" <%= lancamentoEmEdicao?.situacao === status ? 'selected' : '' %>><%= status %></option>
              <% }) %>
            </select>
          </label>

          <div class="actions">
            <button class="button" type="submit"><%= lancamentoEmEdicao ? 'Salvar' : 'Cadastrar' %></button>
            <% if (lancamentoEmEdicao) { %>
              <a class="button button-secondary" href="/registrar">Cancelar</a>
            <% } %>
          </div>
        </form>
      </section>

      <section class="card form-card">
        <form method="get" action="/registrar" class="form-grid filters-grid">
          <label>
            Data inicial
            <input type="date" name="data_inicio" value="<%= filters.data_inicio %>" />
          </label>

          <label>
            Data final
            <input type="date" name="data_fim" value="<%= filters.data_fim %>" />
          </label>

          <label>
            Situacao
            <select name="situacao">
              <option value="">Todas</option>
              <% statusOptions.forEach((status) => { %>
                <option value="<%= status %>" <%= filters.situacao === status ? 'selected' : '' %>><%= status %></option>
              <% }) %>
            </select>
          </label>

          <div class="actions">
            <button class="button" type="submit">Filtrar</button>
            <a class="button button-secondary" href="/registrar">Limpar filtros</a>
          </div>
        </form>
      </section>

      <section class="card">
        <table>
          <thead>
            <tr>
              <th>Descricao</th>
              <th>Data</th>
              <th>Valor</th>
              <th>Situacao</th>
              <th>Acoes</th>
            </tr>
          </thead>
          <tbody>
            <% if (despesas.length === 0) { %>
              <tr>
                <td colspan="5" class="empty">Nenhuma despesa encontrada.</td>
              </tr>
            <% } %>

            <% despesas.forEach((despesa) => { %>
              <tr>
                <td><%= despesa.descricao %></td>
                <td><%= new Date(despesa.data_lancamento).toLocaleDateString('pt-BR') %></td>
                <td>
                  <%= Number(despesa.valor).toLocaleString('pt-BR', {
                    style: 'currency',
                    currency: 'BRL'
                  }) %>
                </td>
                <td><%= despesa.situacao %></td>
                <td class="table-actions">
                  <a class="button button-small button-secondary" href="/registrar?id=<%= despesa.id %>">Editar</a>
                  <form method="post" action="/registrar/<%= despesa.id %>/excluir">
                    <button class="button button-small button-danger" type="submit">Excluir</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </section>
    </main>
  </body>
</html>
